{
  "name": "solus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"next,inngest\" --prefix-colors \"blue,yellow\" \"next dev\" \"npx inngest-cli@latest dev -u http://localhost:3000/api/inngest\"",
    "dev:next": "next dev",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "lint": "next lint",
    "register-webhook": "npx ts-node --project tsconfig.json -e \"require('dotenv').config({path:'.env.local'}); require('./scripts/register-telegram-webhook.ts')\""
  },
  "dependencies": {
    "@ai-sdk/groq": "1.1.9",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@ricky0123/vad-web": "^0.0.30",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.68",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tavily/core": "^0.7.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "ai": "4.3.16",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.2",
    "inngest": "^3.52.6",
    "langsmith": "^0.5.8",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "youtube-transcript": "^1.2.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
